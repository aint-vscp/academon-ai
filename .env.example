# Global leaderboard + Eval Lab sync (optional).
# Without these the app falls back to per-device localStorage and still works.
#
# Use an Upstash Redis (free) REST endpoint:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#
# The Vercel "Upstash for Redis" / KV integration injects KV_REST_API_URL and
# KV_REST_API_TOKEN instead — those are also supported automatically.
# Copy this file to .env.local and fill in the values for local development.
